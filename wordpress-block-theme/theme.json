{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#16216a",
          "name": "Primary (GSA Navy)"
        },
        {
          "slug": "primary-foreground",
          "color": "#ffffff",
          "name": "Primary Foreground"
        },
        {
          "slug": "accent",
          "color": "#6b8a2e",
          "name": "Accent (GPG Olive)"
        },
        {
          "slug": "accent-foreground",
          "color": "#ffffff",
          "name": "Accent Foreground"
        },
        {
          "slug": "background",
          "color": "#ffffff",
          "name": "Background"
        },
        {
          "slug": "foreground",
          "color": "#16216a",
          "name": "Foreground"
        },
        {
          "slug": "muted",
          "color": "#f3f4f6",
          "name": "Muted"
        },
        {
          "slug": "muted-foreground",
          "color": "#6b7f9e",
          "name": "Muted Foreground"
        },
        {
          "slug": "border",
          "color": "#e2e6ed",
          "name": "Border"
        },
        {
          "slug": "cream",
          "color": "#f9f8f5",
          "name": "GPG Cream"
        },
        {
          "slug": "navy-light",
          "color": "#1e3080",
          "name": "Navy Light"
        },
        {
          "slug": "olive-light",
          "color": "#7fa035",
          "name": "Olive Light"
        }
      ],
      "gradients": [
        {
          "slug": "hero-mesh",
          "gradient": "linear-gradient(135deg, #ffffff 0%, rgba(243,244,246,0.2) 50%, rgba(243,244,246,0.5) 100%)",
          "name": "Hero Mesh"
        },
        {
          "slug": "image-overlay",
          "gradient": "linear-gradient(to top, rgba(22,33,106,0.9), rgba(22,33,106,0.5) 40%, rgba(22,33,106,0.2) 60%, transparent)",
          "name": "Image Overlay"
        }
      ],
      "custom": true,
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Titillium Web', system-ui, sans-serif",
          "slug": "heading",
          "name": "Heading (Titillium Web)",
          "fontFace": [
            {
              "fontFamily": "Titillium Web",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": ["https://fonts.gstatic.com/s/titilliumweb/v17/NaPecZTIAOhVxoMyOr9n_E7fdMPmDQ.woff2"]
            },
            {
              "fontFamily": "Titillium Web",
              "fontWeight": "600",
              "fontStyle": "normal",
              "src": ["https://fonts.gstatic.com/s/titilliumweb/v17/NaPDcZTIAOhVxoMyOr9n_E7ffBzCGItzY5abuWI.woff2"]
            },
            {
              "fontFamily": "Titillium Web",
              "fontWeight": "700",
              "fontStyle": "normal",
              "src": ["https://fonts.gstatic.com/s/titilliumweb/v17/NaPDcZTIAOhVxoMyOr9n_E7ffHjDGItzY5abuWI.woff2"]
            }
          ]
        },
        {
          "fontFamily": "'Open Sans', system-ui, sans-serif",
          "slug": "body",
          "name": "Body (Open Sans)",
          "fontFace": [
            {
              "fontFamily": "Open Sans",
              "fontWeight": "300 800",
              "fontStyle": "normal",
              "src": ["https://fonts.gstatic.com/s/opensans/v40/memSYaGs76AUhyKyJzc7TYBs.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "2xs", "size": "0.625rem", "name": "2XS" },
        { "slug": "xs", "size": "0.75rem", "name": "XS" },
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.125rem", "name": "Large" },
        { "slug": "xl", "size": "1.25rem", "name": "XL" },
        { "slug": "2xl", "size": "1.5rem", "name": "2XL" },
        { "slug": "3xl", "size": "1.875rem", "name": "3XL" },
        { "slug": "4xl", "size": "2.25rem", "name": "4XL" },
        { "slug": "5xl", "size": "3rem", "name": "5XL" },
        { "slug": "6xl", "size": "3.75rem", "name": "6XL" }
      ],
      "customFontSize": true,
      "lineHeight": true,
      "letterSpacing": true,
      "textTransform": true,
      "textDecoration": true
    },
    "spacing": {
      "units": ["px", "rem", "%", "vh", "vw"],
      "padding": true,
      "margin": true,
      "blockGap": true,
      "spacingSizes": [
        { "slug": "10", "size": "0.25rem", "name": "1" },
        { "slug": "20", "size": "0.5rem", "name": "2" },
        { "slug": "30", "size": "0.75rem", "name": "3" },
        { "slug": "40", "size": "1rem", "name": "4" },
        { "slug": "50", "size": "1.5rem", "name": "5" },
        { "slug": "60", "size": "2rem", "name": "6" },
        { "slug": "70", "size": "3rem", "name": "7" },
        { "slug": "80", "size": "4rem", "name": "8" },
        { "slug": "90", "size": "6rem", "name": "9" }
      ]
    },
    "layout": {
      "contentSize": "1400px",
      "wideSize": "1400px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "presets": [
        {
          "slug": "card",
          "shadow": "0 4px 20px -4px rgba(22, 33, 106, 0.1)",
          "name": "Card"
        },
        {
          "slug": "card-hover",
          "shadow": "0 12px 40px -8px rgba(22, 33, 106, 0.15)",
          "name": "Card Hover"
        },
        {
          "slug": "elegant",
          "shadow": "0 20px 60px -12px rgba(0, 0, 0, 0.1)",
          "name": "Elegant"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "padding": {
        "left": "var(--wp--preset--spacing--50)",
        "right": "var(--wp--preset--spacing--50)"
      }
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "clamp(1.75rem, 5vw, 3.75rem)",
          "fontWeight": "700",
          "lineHeight": "1.15",
          "textTransform": "uppercase",
          "letterSpacing": "-0.025em"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "clamp(1.5rem, 4vw, 2.5rem)",
          "fontWeight": "600",
          "lineHeight": "1.2",
          "textTransform": "uppercase",
          "letterSpacing": "-0.025em"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "clamp(1rem, 3vw, 1.5rem)",
          "fontWeight": "600",
          "lineHeight": "1.2",
          "textTransform": "uppercase",
          "letterSpacing": "-0.025em"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "clamp(0.875rem, 2vw, 1.25rem)",
          "fontWeight": "600",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        },
        "typography": {
          "textDecoration": "none"
        }
      },
      "button": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--primary-foreground)"
        },
        "border": {
          "radius": "0 0.75rem 0 0",
          "width": "2px",
          "color": "var(--wp--preset--color--primary)"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--navy-light)"
          }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "500"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "page-diensten",
      "title": "Diensten",
      "postTypes": ["page"]
    },
    {
      "name": "page-over-ons",
      "title": "Over Ons",
      "postTypes": ["page"]
    },
    {
      "name": "page-projecten",
      "title": "Projecten",
      "postTypes": ["page"]
    },
    {
      "name": "page-duurzaamheid",
      "title": "Duurzaamheid",
      "postTypes": ["page"]
    },
    {
      "name": "page-contact",
      "title": "Contact",
      "postTypes": ["page"]
    },
    {
      "name": "page-privacy",
      "title": "Privacy",
      "postTypes": ["page"]
    },
    {
      "name": "page-voorwaarden",
      "title": "Voorwaarden",
      "postTypes": ["page"]
    }
  ],
  "patterns": [
    "gpg-hero-split",
    "gpg-client-logos",
    "gpg-services-bento",
    "gpg-stats-ticker",
    "gpg-why-gpg",
    "gpg-process-timeline",
    "gpg-projects-showcase",
    "gpg-testimonial",
    "gpg-faq-homepage",
    "gpg-cta-contact",
    "gpg-page-hero",
    "gpg-footer-cta"
  ]
}
